<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Professional SEO Services by Fahim Islam | Rank #1 on Google</title>
<meta name="description" content="Fahim Islam is a professional SEO Expert & Content Writer helping businesses rank higher on Google, drive organic traffic, and grow revenue.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --bg:#06090f;--bg2:#0a0e18;--card:#0f1522;--card2:#131a28;
  --ac:#00d4ff;--ac2:#0ea5e9;--ac3:#06b6d4;
  --green:#22c55e;--yellow:#f59e0b;--red:#f87171;
  --glow:rgba(0,212,255,.12);--glow2:rgba(0,212,255,.25);--glow3:rgba(0,212,255,.06);
  --t1:#f0f6ff;--t2:#8fa3bc;--t3:#4d6070;
  --bd:rgba(255,255,255,.07);--bda:rgba(0,212,255,.18);--bda2:rgba(0,212,255,.35);
  --sh:0 4px 28px rgba(0,0,0,.5);--sg:0 0 50px rgba(0,212,255,.1);
  --r:18px;--r2:10px;--ff:'Outfit',sans-serif;--fb:'Inter',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--bg);color:var(--t1);line-height:1.7;overflow-x:hidden}
a{text-decoration:none;color:inherit}
ul{list-style:none}
img{max-width:100%;display:block}
.wrap{max-width:1200px;margin:0 auto;padding:0 24px}

/* SCROLL PROGRESS */
#spb{position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(90deg,var(--ac),var(--ac2));z-index:9999;box-shadow:0 0 10px var(--ac);transition:width .1s}

/* ── NAV ── */
nav{position:sticky;top:0;z-index:100;background:rgba(6,9,15,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--bd);padding:0 24px}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:68px}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--ff);font-weight:700;font-size:1.2rem;letter-spacing:0}
.logo-icon{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--ac),var(--ac2));display:flex;align-items:center;justify-content:center;font-size:.78rem;font-weight:800;color:#000;letter-spacing:.5px}
.logo-sub{font-size:.7rem;color:var(--t3);font-weight:400;display:block;letter-spacing:.05em}
.nav-links{display:flex;gap:4px}
.nav-links a{font-size:.85rem;font-weight:500;padding:7px 13px;border-radius:8px;color:var(--t2);transition:all .25s}
.nav-links a:hover{color:var(--t1);background:var(--glow3)}
.nav-cta{padding:9px 22px;border-radius:50px;background:var(--ac);color:#000;font-weight:700;font-size:.85rem;transition:all .25s;white-space:nowrap}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px var(--glow2)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;background:none;border:none}
.hamburger span{width:22px;height:2px;background:var(--t1);border-radius:2px;transition:.3s}

/* ── HERO ── */
.hero{position:relative;overflow:hidden;padding:100px 24px 80px;background:var(--bg)}
.hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(var(--bd) 1px,transparent 1px),linear-gradient(90deg,var(--bd) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse 70% 60% at 55% 40%,black 20%,transparent 75%);opacity:.6}
.orb{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none}
.o1{width:600px;height:600px;background:radial-gradient(circle,rgba(0,212,255,.07) 0%,transparent 70%);top:-150px;right:-100px}
.o2{width:450px;height:450px;background:radial-gradient(circle,rgba(99,102,241,.06) 0%,transparent 70%);bottom:-100px;left:-100px}
.hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 420px;gap:64px;align-items:center;position:relative;z-index:1}

.badge{display:inline-flex;align-items:center;gap:8px;padding:7px 16px;border-radius:50px;background:rgba(0,212,255,.08);border:1px solid var(--bda);font-size:.75rem;color:var(--ac);margin-bottom:20px;font-weight:500;letter-spacing:.03em}
.badge-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 1.5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hero h1{font-family:var(--ff);font-size:clamp(2.2rem,4.5vw,4rem);font-weight:800;line-height:1.15;letter-spacing:0;margin-bottom:10px}
.hero h1 .ac{color:var(--ac)}
.hero h1 .yw{color:var(--yellow)}
.hero-sub-role{font-size:1rem;color:var(--t2);margin-bottom:20px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.role-chip{background:var(--glow);border:1px solid var(--bda);color:var(--ac);border-radius:50px;padding:3px 12px;font-size:.8rem;font-weight:600}
.hero-desc{font-size:.97rem;color:var(--t2);max-width:500px;margin-bottom:32px;line-height:1.8}
.hero-desc strong{color:var(--t1)}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px}
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:50px;background:var(--ac);color:#000;font-weight:700;font-size:.92rem;transition:all .25s;border:none;cursor:pointer}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 32px var(--glow2)}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:50px;border:1px solid var(--bda);color:var(--t1);font-weight:600;font-size:.92rem;background:var(--glow3);transition:all .25s}
.btn-ghost:hover{background:var(--glow);border-color:var(--ac);transform:translateY(-3px)}
.hero-stats{display:flex;gap:24px;align-items:center;flex-wrap:wrap}
.stat .num{font-family:var(--ff);font-size:1.9rem;font-weight:700;color:var(--t1);line-height:1;letter-spacing:0}
.stat .num span{color:var(--ac)}
.stat .lbl{font-size:.7rem;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-top:3px}
.stat-div{width:1px;height:36px;background:var(--bd)}

/* HERO VISUAL */
.hero-visual{position:relative}
.mockup-card{background:var(--card);border:1px solid var(--bda);border-radius:20px;padding:22px;animation:float 5s ease-in-out infinite;box-shadow:var(--sg)}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.mock-bar{display:flex;gap:6px;margin-bottom:14px}
.mock-bar span{width:10px;height:10px;border-radius:50%}
.mock-bar span:nth-child(1){background:#ff5f57}
.mock-bar span:nth-child(2){background:#febc2e}
.mock-bar span:nth-child(3){background:#28c840}
.mock-label{font-size:.7rem;color:var(--t3);margin-bottom:8px;text-transform:uppercase;letter-spacing:.08em}
.chart-bars{display:flex;align-items:flex-end;gap:7px;height:100px;margin-bottom:8px}
.bar{border-radius:4px 4px 0 0;flex:1;background:rgba(0,212,255,.25);min-width:16px}
.bar:nth-child(1){height:25%}
.bar:nth-child(2){height:42%}
.bar:nth-child(3){height:35%}
.bar:nth-child(4){height:58%}
.bar:nth-child(5){height:50%}
.bar:nth-child(6){height:76%;background:rgba(255,255,255,.5)}
.bar:nth-child(7){height:95%;background:var(--ac)}
.mock-foot{font-size:.68rem;color:var(--t3);text-align:center}
.rank-pills{display:flex;flex-direction:column;gap:7px;margin-top:12px}
.rank-pill{display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.04);border:1px solid var(--bd);border-radius:8px;padding:8px 12px}
.rank-pill .kw{font-size:.75rem;color:var(--t2);flex:1}
.rank-pill .pos{font-size:.76rem;font-weight:700;color:var(--yellow);white-space:nowrap}
.rank-pill .arr{font-size:.7rem;color:var(--green)}
.float-badge{position:absolute;bottom:-14px;right:-12px;background:var(--card2);border:1px solid var(--bda);border-radius:14px;padding:12px 16px;box-shadow:var(--sh);display:flex;align-items:center;gap:10px;animation:float2 4s ease-in-out infinite}
@keyframes float2{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.fb-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--ac),var(--ac2));border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1rem;color:#000}
.fb-text strong{display:block;font-size:.85rem;font-weight:700;color:var(--t1)}
.fb-text span{font-size:.68rem;color:var(--t3)}

/* ── SHARED SECTION ── */
.sec{padding:90px 0}
.sec-alt{background:var(--bg2)}
.sh{text-align:center;margin-bottom:64px}
.eyebrow{display:inline-block;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.18em;color:var(--ac);margin-bottom:12px;padding:5px 15px;border-radius:50px;background:var(--glow);border:1px solid var(--bda)}
.sh h2{font-family:var(--ff);font-size:clamp(1.6rem,3vw,2.5rem);font-weight:700;letter-spacing:0;line-height:1.25;margin-bottom:14px}
.sh h2 span{color:var(--ac)}
.sh p{color:var(--t2);max-width:520px;margin:0 auto;font-size:.95rem;line-height:1.75}

/* ── WHY ME / PROBLEM ── */
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;margin-bottom:56px}
.why-left h3{font-family:var(--ff);font-size:clamp(1.4rem,2.2vw,1.9rem);font-weight:700;margin-bottom:16px;line-height:1.3;letter-spacing:0}
.why-left p{color:var(--t2);font-size:.93rem;line-height:1.8;margin-bottom:12px}
.why-left p strong{color:var(--t1)}
.pain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.pain-card{background:var(--card);border-radius:14px;padding:24px;border-left:3px solid var(--red);transition:all .3s}
.pain-card:hover{transform:translateY(-4px);box-shadow:var(--sh)}
.pain-icon{font-size:1.4rem;margin-bottom:10px}
.pain-card h4{font-size:.9rem;font-weight:700;margin-bottom:8px}
.pain-card p{font-size:.8rem;color:var(--t2);line-height:1.65}

/* ── SERVICES ── */
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.svc-card{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);padding:32px 26px;position:relative;overflow:hidden;transition:all .3s}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--ac),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.svc-card:hover{background:var(--card2);border-color:var(--bda);transform:translateY(-6px);box-shadow:var(--sg)}
.svc-card:hover::before{transform:scaleX(1)}
.svc-icon{width:50px;height:50px;border-radius:13px;background:var(--glow);border:1px solid var(--bda);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--ac);margin-bottom:18px;transition:all .3s}
.svc-card:hover .svc-icon{background:var(--ac);color:#000}
.svc-card h3{font-family:var(--ff);font-size:1rem;font-weight:700;margin-bottom:10px}
.svc-card p{color:var(--t2);font-size:.85rem;line-height:1.7}
.svc-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px}
.svc-tag{font-size:.68rem;padding:3px 10px;border-radius:50px;background:var(--bg);border:1px solid var(--bd);color:var(--t3)}

/* ── PROCESS ── */
.process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
.process-steps::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,var(--bda),var(--bda),transparent)}
.step{text-align:center;padding:20px 16px;position:relative}
.step-num{width:56px;height:56px;border-radius:50%;background:var(--card);border:2px solid var(--bda);display:flex;align-items:center;justify-content:center;font-family:var(--ff);font-size:1rem;font-weight:700;color:var(--ac);margin:0 auto 18px;position:relative;z-index:1;transition:all .3s;letter-spacing:0}
.step:hover .step-num{background:var(--ac);color:#000;border-color:var(--ac);box-shadow:0 0 30px var(--glow2)}
.step h4{font-size:.9rem;font-weight:700;margin-bottom:8px;font-family:var(--ff)}
.step p{font-size:.8rem;color:var(--t2);line-height:1.6}

/* ── RESULTS / PORTFOLIO ── */
.results-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.result-card{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;transition:all .3s}
.result-card:hover{transform:translateY(-6px);box-shadow:var(--sg);border-color:var(--bda)}
.rc-img{height:180px;overflow:hidden;position:relative}
.rc-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
.result-card:hover .rc-img img{transform:scale(1.07)}
.rc-category{position:absolute;top:12px;left:12px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;padding:4px 11px;border-radius:50px;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);color:var(--ac);border:1px solid var(--bda)}
.rc-body{padding:22px}
.rc-body h3{font-family:var(--ff);font-size:.95rem;font-weight:700;margin-bottom:8px}
.rc-body p{color:var(--t2);font-size:.82rem;margin-bottom:12px}
.rc-result{font-size:.82rem;color:var(--green);font-weight:600;display:flex;align-items:center;gap:5px}

/* ── TESTIMONIALS ── */
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.test-card{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);padding:28px;position:relative;transition:all .3s}
.test-card::before{content:'"';position:absolute;top:14px;right:20px;font-size:3.5rem;color:var(--ac);opacity:.09;font-family:Georgia,serif;line-height:1}
.test-card.featured{border-color:var(--bda);background:linear-gradient(135deg,var(--card),rgba(0,212,255,.04));box-shadow:var(--sg)}
.test-card:hover{transform:translateY(-5px);border-color:var(--bda)}
.stars{color:#fbbf24;font-size:.9rem;margin-bottom:12px;letter-spacing:2px}
.test-card p{color:var(--t2);font-size:.84rem;line-height:1.8;margin-bottom:20px;font-style:italic}
.test-author{display:flex;align-items:center;gap:12px}
.test-author img{width:42px;height:42px;border-radius:50%;border:2px solid var(--bda);object-fit:cover}
.test-author strong{display:block;font-size:.84rem;font-weight:700}
.test-author span{font-size:.7rem;color:var(--t3)}

/* ── PRICING ── */
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:start}
.plan{background:var(--card);border:1px solid var(--bd);border-radius:var(--r);padding:34px 28px;transition:all .3s;position:relative}
.plan.popular{border-color:var(--bda2);background:linear-gradient(180deg,rgba(0,212,255,.06),var(--card));box-shadow:var(--sg)}
.popular-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--ac);color:#000;font-size:.7rem;font-weight:800;padding:4px 16px;border-radius:50px;white-space:nowrap;text-transform:uppercase;letter-spacing:.05em}
.plan:hover{transform:translateY(-5px)}
.plan-name{font-family:var(--ff);font-size:1rem;font-weight:700;margin-bottom:8px}
.plan-price{margin-bottom:6px}
.plan-price .amount{font-family:var(--ff);font-size:2.2rem;font-weight:800;color:var(--ac)}
.plan-price .period{font-size:.8rem;color:var(--t3)}
.plan-desc{font-size:.8rem;color:var(--t3);margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid var(--bd)}
.plan-features{display:flex;flex-direction:column;gap:11px;margin-bottom:28px}
.pf{display:flex;align-items:flex-start;gap:9px;font-size:.83rem;color:var(--t2)}
.pf i{color:var(--green);font-size:.75rem;margin-top:4px;flex-shrink:0}
.pf.no{color:var(--t3)}
.pf.no i{color:var(--t3)}
.plan-btn{display:block;text-align:center;padding:12px 20px;border-radius:50px;font-weight:700;font-size:.88rem;transition:all .25s;border:1.5px solid var(--bda);color:var(--t1);background:transparent}
.plan-btn:hover,.plan.popular .plan-btn{background:var(--ac);color:#000;border-color:var(--ac)}

/* ── FAQ ── */
.faq-list{display:flex;flex-direction:column;gap:14px;max-width:780px;margin:0 auto}
.faq-item{background:var(--card);border:1px solid var(--bd);border-radius:var(--r2);overflow:hidden;transition:border-color .25s}
.faq-item.open{border-color:var(--bda)}
.faq-q{width:100%;display:flex;justify-content:space-between;align-items:center;padding:18px 22px;font-size:.93rem;font-weight:600;color:var(--t1);cursor:pointer;background:none;border:none;font-family:var(--fb);text-align:left;gap:12px}
.faq-icon{width:26px;height:26px;border-radius:50%;background:var(--glow);border:1px solid var(--bda);display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--ac);transition:transform .25s;flex-shrink:0}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease,padding .3s;font-size:.87rem;color:var(--t2);padding:0 22px;line-height:1.8}
.faq-item.open .faq-a{max-height:300px;padding:0 22px 18px}

/* ── TOOLS ── */
.tools-grid{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:16px}
.tool-chip{display:flex;align-items:center;gap:7px;padding:9px 18px;border-radius:50px;background:var(--card);border:1px solid var(--bd);font-size:.83rem;color:var(--t2);transition:all .3s}
.tool-chip:hover{border-color:var(--bda);color:var(--ac)}
.tool-chip i{color:var(--ac);font-size:.8rem}

/* ── FINAL CTA ── */
.final-cta{background:linear-gradient(135deg,#070b14 0%,#0a1525 50%,#070b14 100%);padding:90px 24px;text-align:center;position:relative;overflow:hidden}
.final-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 70% at 50% 50%,rgba(0,212,255,.06) 0%,transparent 70%)}
.final-cta h2{font-family:var(--ff);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;letter-spacing:0;margin-bottom:18px;position:relative;z-index:1}
.final-cta h2 span{color:var(--ac)}
.final-cta p{color:var(--t2);max-width:520px;margin:0 auto 36px;font-size:.97rem;line-height:1.75;position:relative;z-index:1}
.cta-buttons{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:36px;position:relative;z-index:1}
.cta-trust{display:flex;gap:28px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}
.cta-trust-item{display:flex;align-items:center;gap:7px;font-size:.82rem;color:rgba(255,255,255,.55)}
.cta-trust-item i{color:var(--green);font-size:.75rem}

/* ── FOOTER ── */
footer{background:var(--bg2);border-top:1px solid var(--bd);padding:56px 0 0}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:44px;margin-bottom:44px}
.footer-brand p{color:var(--t3);font-size:.84rem;margin:12px 0 20px;line-height:1.7}
.footer-col h4{font-family:var(--ff);font-size:.9rem;font-weight:700;margin-bottom:16px;color:var(--t1)}
.footer-col ul{display:flex;flex-direction:column;gap:8px}
.footer-col a{color:var(--t3);font-size:.83rem;transition:all .25s}
.footer-col a:hover{color:var(--ac);padding-left:4px}
.footer-social{display:flex;gap:9px;margin-top:4px}
.social-link{width:38px;height:38px;border-radius:50%;background:var(--card);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:.8rem;color:var(--t2);transition:all .25s}
.social-link:hover{background:var(--ac);color:#000;border-color:var(--ac);transform:translateY(-3px)}
.footer-bottom{border-top:1px solid var(--bd);padding:20px 0;display:flex;justify-content:space-between;align-items:center;font-size:.78rem;color:var(--t3)}
.footer-logo{font-family:var(--ff);font-size:1.3rem;font-weight:800;margin-bottom:4px;letter-spacing:0}
.footer-logo span{color:var(--ac)}

/* WhatsApp */
.wa-btn{position:fixed;bottom:24px;right:24px;width:56px;height:56px;border-radius:50%;background:#25d366;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(37,211,102,.4);z-index:999;transition:all .3s}
.wa-btn:hover{transform:scale(1.1);box-shadow:0 10px 32px rgba(37,211,102,.55)}

/* AOS */
[data-a]{opacity:0;transform:translateY(24px);transition:opacity .65s ease,transform .65s ease}
[data-a].in{opacity:1;transform:translateY(0)}
[data-d="1"]{transition-delay:.1s}
